rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function projectOwner(projectId) {
      return signedIn() &&
        get(/databases/$(database)/documents/projects/$(projectId)).data.createdByUid == request.auth.uid;
    }

    function ticketOwner(projectId, ticketId) {
      return signedIn() &&
        get(/databases/$(database)/documents/projects/$(projectId)/tickets/$(ticketId)).data.createdByUid == request.auth.uid;
    }

    match /projects/{projectId} {
      allow read: if signedIn();

      allow create: if signedIn()
        && request.resource.data.createdByUid == request.auth.uid;

      allow update: if signedIn() && (
        resource.data.createdByUid == request.auth.uid ||
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ticketCount']) &&
          request.resource.data.ticketCount is int &&
          resource.data.ticketCount is int &&
          (
            request.resource.data.ticketCount == resource.data.ticketCount + 1 ||
            request.resource.data.ticketCount == resource.data.ticketCount - 1
          )
        )
      );

      allow delete: if signedIn()
        && resource.data.createdByUid == request.auth.uid;

      match /tickets/{ticketId} {
        allow read: if signedIn();

        allow create: if signedIn()
          && (
            request.resource.data.createdByUid == request.auth.uid ||
            projectOwner(projectId)
          );

        allow update: if signedIn() && (
          (
            resource.data.createdByUid == request.auth.uid &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['title', 'description', 'category'])
          ) ||
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['votes']) &&
            request.resource.data.votes is int &&
            resource.data.votes is int &&
            request.resource.data.votes >= resource.data.votes - 2 &&
            request.resource.data.votes <= resource.data.votes + 2
          ) ||
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['commentCount']) &&
            request.resource.data.commentCount is int &&
            (
              (
                resource.data.keys().hasAny(['commentCount']) &&
                resource.data.commentCount is int &&
                request.resource.data.commentCount == resource.data.commentCount + 1
              ) ||
              (
                !resource.data.keys().hasAny(['commentCount']) &&
                request.resource.data.commentCount == 1
              )
            )
          )
        );

        allow delete: if signedIn() && (
          resource.data.createdByUid == request.auth.uid ||
          projectOwner(projectId)
        );

        match /comments/{commentId} {
          allow read: if signedIn();

          allow create: if signedIn()
            && (
              request.resource.data.createdByUid == request.auth.uid ||
              projectOwner(projectId)
            );

          allow update: if false;

          allow delete: if signedIn() && (
            resource.data.createdByUid == request.auth.uid ||
            projectOwner(projectId) ||
            ticketOwner(projectId, ticketId)
          );
        }
      }

      match /votes/{voteId} {
        allow read: if signedIn();

        allow create: if signedIn()
          && request.resource.data.userId == request.auth.uid;

        allow update: if signedIn()
          && resource.data.userId == request.auth.uid
          && request.resource.data.userId == request.auth.uid;

        allow delete: if signedIn() && (
          resource.data.userId == request.auth.uid ||
          projectOwner(projectId)
        );
      }
    }
  }
}
